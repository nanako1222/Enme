<%# ─── 管理者ログイン ───────────────────────── %>
<div class="container py-5">
  <div class="admin-auth-card mx-auto mt-4">

    <h1 class="admin-auth__title text-center mb-4">
      <i class="fas fa-lock me-2"></i>管理者ログイン
    </h1>

    <%= form_with model: @admin, url: admin_session_path, local: true do |f| %>

      <div class="mb-4">
        <%= f.label :email, "メールアドレス", class: "auth-form__label" %>
        <%= f.email_field :email, class: "form-control auth-form__input" %>
      </div>

      <div class="mb-4">
        <%= f.label :password, "パスワード", class: "auth-form__label" %>
        <%= f.password_field :password, class: "form-control auth-form__input" %>
      </div>

      <div class="d-grid mt-2">
        <%= button_tag type: :submit, class: "btn admin-auth-submit-btn" do %>
          <i class="fas fa-sign-in-alt me-1"></i>ログイン
        <% end %>
      </div>

    <% end %>

  </div>
</div>
