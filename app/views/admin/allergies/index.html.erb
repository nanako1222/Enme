<div class="container">
  <div class="col-11 col-md-10 mx-auto">

    <div class="text-center mt-5">
      <h4 class="text-center"><strong>アレルゲン一覧・追加</strong></h4>
    </div>

    <% flash.each do |key, value| %>
      <p class="alert alert-<%= key %>"><%= value %></p>
    <% end %>

    <div class="row mt-4">
      <div class="col-md-5">
        <%= form_with model: @allergy, url: admin_allergies_path, method: :post do |f| %>
          <div class="row mt-3 align-items-center">
            <%= f.label :allergen, class: "col-md-4" %>
            <%= f.text_field :allergen, class: "col-md-8" %>
          </div>
          <div class="mt-4 text-center">
            <%= f.submit '新規登録', class: "btn btn-success" %>
          </div>
        <% end %>
      </div>

      <div class="col-md-7">
        <table class="table table-hover">
          <thead class="table-secondary">
            <th>アレルゲン</th>
            <th></th>
            <th></th>
          </thead>
          <% @allergies.each do |allergy| %>
            <tr>
              <td><%= allergy.allergen %></td>
              <td><%= link_to "編集", edit_admin_allergy_path(allergy), class: "btn btn-success" %></td>
              <td><%= link_to "削除", admin_allergy_path(allergy), method: :delete, "data-confirm" => "本当に削除しますか？", class: "btn btn-danger active" %></td>
            </tr>
          <% end %>
        </table>
        <div class="text-end mt-3"><%= paginate @allergies %></div>
      </div>
    </div>

  </div>
</div>
