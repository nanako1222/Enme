<%# ─── ヒーロー ─────────────────────────── %>
<div class="auth-hero">
  <div class="container text-center py-4">
    <h1 class="auth-hero__title">アレルゲン編集</h1>
    <p class="auth-hero__sub">「<%= @allergy.allergen %>」の名称を変更します</p>
  </div>
</div>

<div class="container py-5">
  <div class="auth-card mx-auto">

    <%= form_with model: @allergy, url: admin_allergy_path, method: :patch do |f| %>

      <div class="mb-4">
        <%= f.label :allergen, "アレルゲン名", class: "auth-form__label" %>
        <%= f.text_field :allergen, required: true, class: "form-control auth-form__input" %>
      </div>

      <div class="d-grid mt-2">
        <%= f.submit "保存する", class: "btn admin-auth-submit-btn" %>
      </div>

    <% end %>

    <hr class="auth-divider my-4">
    <div class="text-center">
      <%= link_to admin_allergies_path, class: "btn auth-register-btn" do %>
        <i class="fas fa-arrow-left me-1"></i>一覧に戻る
      <% end %>
    </div>

  </div>
</div>
