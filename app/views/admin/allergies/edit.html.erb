<div class="container">
  <div class="col-11 col-md-8 mx-auto">

    <div class="text-center mt-5">
      <h4 class="text-center"><strong>アレルゲン編集</strong></h4>
    </div>

    <% flash.each do |key, value| %>
      <p class="alert alert-<%= key %>"><%= value %></p>
    <% end %>

    <%= form_with model: @allergy, url: admin_allergy_path, method: :patch do |f| %>

      <div class="row mt-3 align-items-center">
        <%= f.label :allergen, class: "col-md-4" %>
        <%= f.text_field :allergen, class: "col-md-8" %>
      </div>

      <div class="mt-4 text-center">
        <%= f.submit '保存', class: "btn btn-success" %>
      </div>

    <% end %>

  </div>
</div>
