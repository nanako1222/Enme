<%# ─── 管理者帯 ──────────────────────── %>
<div class="admin-notice-band">
  <div class="container">
    <p><i class="fas fa-shield-alt me-1"></i>管理者ページ｜地域一覧</p>
  </div>
</div>

<%# ─── ページヘッダー ─────────────────── %>
<div class="menu-list-header">
  <div class="container py-4">
    <div>
      <h1 class="menu-list-header__title">
        <i class="fas fa-map-marker-alt me-2"></i>地域一覧（都道府県）
      </h1>
      <p class="menu-list-header__count">都道府県をクリックするとエリア一覧を確認できます</p>
    </div>
  </div>
</div>

<%# ─── テーブル ────────────────────────── %>
<div class="container py-4 pb-5">
  <div class="mypage-card" style="max-width: 480px;">
    <table class="admin-table">
      <thead>
        <tr>
          <th>都道府県</th>
          <th></th>
        </tr>
      </thead>
      <tbody>
        <% @states.each do |state| %>
          <tr>
            <td><%= state.state %></td>
            <td style="width:80px;">
              <%= link_to "エリア確認", admin_areas_path(state.id), class: "admin-action-btn" %>
            </td>
          </tr>
        <% end %>
      </tbody>
    </table>
    <div class="d-flex justify-content-center mt-4">
      <%= paginate @states %>
    </div>
  </div>
</div>
