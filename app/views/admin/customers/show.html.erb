<%# ─── 管理者帯 ──────────────────────── %>
<div class="admin-notice-band">
  <div class="container">
    <p><i class="fas fa-shield-alt me-1"></i>管理者ページ｜顧客詳細</p>
  </div>
</div>

<%# ─── ページヘッダー ─────────────────── %>
<div class="menu-list-header">
  <div class="container py-4">
    <div class="d-flex align-items-center justify-content-between flex-wrap gap-3">
      <div>
        <h1 class="menu-list-header__title">
          <i class="fas fa-user me-2"></i>顧客詳細
        </h1>
        <p class="menu-list-header__count"><strong><%= @customer.full_name %></strong> さん</p>
      </div>
      <div class="d-flex gap-2">
        <%= link_to admin_customers_path, class: "btn menu-back-btn" do %>
          <i class="fas fa-arrow-left me-1"></i>顧客一覧に戻る
        <% end %>
        <%= link_to edit_admin_customer_path(@customer), class: "btn admin-auth-submit-btn" do %>
          <i class="fas fa-pen-nib me-1"></i>編集する
        <% end %>
      </div>
    </div>
  </div>
</div>

<%# ─── 情報カード ──────────────────────── %>
<div class="container py-4 pb-5">
  <div class="mypage-card" style="max-width: 720px;">

    <h2 class="mypage-card__section-title">
      <i class="fas fa-id-card me-2"></i>基本情報
    </h2>

    <dl class="mypage-dl">
      <div class="mypage-dl__row">
        <dt class="mypage-dl__label">会員ID</dt>
        <dd class="mypage-dl__value text-muted"><%= @customer.id %></dd>
      </div>
      <div class="mypage-dl__row">
        <dt class="mypage-dl__label">氏名</dt>
        <dd class="mypage-dl__value"><%= @customer.full_name %></dd>
      </div>
      <div class="mypage-dl__row">
        <dt class="mypage-dl__label">フリガナ</dt>
        <dd class="mypage-dl__value"><%= @customer.full_name_kana %></dd>
      </div>
      <div class="mypage-dl__row">
        <dt class="mypage-dl__label">メールアドレス</dt>
        <dd class="mypage-dl__value"><%= @customer.email %></dd>
      </div>
      <div class="mypage-dl__row">
        <dt class="mypage-dl__label">都道府県</dt>
        <dd class="mypage-dl__value"><%= @state %></dd>
      </div>
      <div class="mypage-dl__row">
        <dt class="mypage-dl__label">地域エリア</dt>
        <dd class="mypage-dl__value"><%= @area %></dd>
      </div>
      <div class="mypage-dl__row">
        <dt class="mypage-dl__label">電話番号</dt>
        <dd class="mypage-dl__value"><%= @customer.telephone_number.presence || "（未登録）" %></dd>
      </div>
      <div class="mypage-dl__row">
        <dt class="mypage-dl__label">会員状況</dt>
        <dd class="mypage-dl__value">
          <% if @customer.is_valid %>
            <span class="admin-badge admin-badge--valid">有効</span>
          <% else %>
            <span class="admin-badge admin-badge--invalid">退会</span>
          <% end %>
        </dd>
      </div>
    </dl>

    <% if @customer.allergies.any? %>
      <h2 class="mypage-card__section-title mt-4">
        <i class="fas fa-exclamation-triangle me-2"></i>登録アレルゲン
      </h2>
      <div class="d-flex flex-wrap gap-2 mt-3">
        <% @customer.allergies.each do |allergy| %>
          <span class="menu-allergen-tag"><%= allergy.allergen %></span>
        <% end %>
      </div>
    <% end %>

  </div>
</div>
