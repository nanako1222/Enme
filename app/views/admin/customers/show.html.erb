<div class="container">
  <div class="col-11 col-md-8 mx-auto">

    <% if flash[:notice] %>
      <%= notice %>
    <% end %>

    <div class="text-center mt-5">
      <h4 class="text-center"><strong><%= "#{@customer.full_name}さんの会員詳細" %></strong></h4>
    </div>

    <div class='flashing mt-2'>
      <p>※現在登録されているデータは架空です</p>
    </div>

    <table class="table table-hover mt-4">
      <tr>
        <th>会員ID</th>
        <td><%= @customer.id %></td>
      </tr>
      <tr>
        <th>氏名</th>
        <td><%= @customer.full_name %></td>
      </tr>
      <tr>
        <th>フリガナ</th>
        <td><%= @customer.full_name_kana %></td>
      </tr>
      <tr>
        <th>メールアドレス</th>
        <td><%= @customer.email %></td>
      </tr>
      <tr>
        <th>都道府県</th>
        <td><%= @state %></td>
      </tr>
      <tr>
        <th>地域エリア</th>
        <td><%= @area %></td>
      </tr>
      <tr>
        <th>電話番号</th>
        <td><%= @customer.telephone_number %></td>
      </tr>
      <tr>
        <th>アレルギー一覧</th>
        <td>
          <% @customer.allergies.each do |allergy| %>
            <%= allergy.allergen %>
          <% end %>
        </td>
      </tr>
      <tr>
        <th>会員状況</th>
        <td>
          <% if @customer.is_valid == false %>
            <p class="customer_valid">退会</p>
          <% else %>
            <p class="customer_valid2">有効</p>
          <% end %>
        </td>
      </tr>
    </table>

    <div class="text-center mt-3">
      <%= link_to "編集する", edit_admin_customer_path(@customer), class: "btn btn-success" %>
    </div>

  </div>
</div>
