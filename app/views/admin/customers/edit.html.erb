<%# ─── ヒーロー ─────────────────────────── %>
<div class="auth-hero">
  <div class="container text-center py-4">
    <h1 class="auth-hero__title">顧客情報編集</h1>
    <p class="auth-hero__sub"><%= @customer.full_name %> さんの情報を編集します</p>
  </div>
</div>

<div class="container py-5">
  <div class="auth-card auth-card--wide mx-auto">

    <%= form_with model: @customer, url: admin_customer_path, method: :patch do |f| %>

      <%# 名前 %>
      <div class="mb-4">
        <p class="auth-form__label mb-2">氏名</p>
        <div class="d-flex gap-2">
          <div class="flex-fill">
            <%= f.label :last_name, "姓", class: "auth-form__label" %>
            <%= f.text_field :last_name, required: true, class: "form-control auth-form__input" %>
          </div>
          <div class="flex-fill">
            <%= f.label :first_name, "名", class: "auth-form__label" %>
            <%= f.text_field :first_name, required: true, class: "form-control auth-form__input" %>
          </div>
        </div>
      </div>

      <%# フリガナ %>
      <div class="mb-4">
        <p class="auth-form__label mb-2">フリガナ</p>
        <div class="d-flex gap-2">
          <div class="flex-fill">
            <%= f.label :last_name_kana, "セイ", class: "auth-form__label" %>
            <%= f.text_field :last_name_kana, required: true, class: "form-control auth-form__input" %>
          </div>
          <div class="flex-fill">
            <%= f.label :first_name_kana, "メイ", class: "auth-form__label" %>
            <%= f.text_field :first_name_kana, required: true, class: "form-control auth-form__input" %>
          </div>
        </div>
      </div>

      <%# メールアドレス %>
      <div class="mb-4">
        <%= f.label :email, "メールアドレス", class: "auth-form__label" %>
        <%= f.email_field :email, required: true, class: "form-control auth-form__input" %>
      </div>

      <%# 都道府県・エリア %>
      <div class="row g-3 mb-4">
        <div class="col-md-6">
          <%= f.label :state_id, "都道府県", class: "auth-form__label" %>
          <%= f.collection_select :state_id, State.all, :id, :state,
              { include_blank: "選択してください" },
              { class: "form-select auth-form__input" } %>
        </div>
        <div class="col-md-6">
          <%= f.label :area_id, "地域エリア", class: "auth-form__label" %>
          <div id="areas_select_customer">
            <%= render partial: 'shared/areas', locals: { areas: @area } %>
          </div>
        </div>
      </div>

      <%# 電話番号 %>
      <div class="mb-4">
        <%= f.label :telephone_number, "電話番号", class: "auth-form__label" %>
        <%= f.text_field :telephone_number, class: "form-control auth-form__input" %>
      </div>

      <%# 会員状況 %>
      <div class="mb-4">
        <p class="auth-form__label mb-2">会員状況</p>
        <div class="admin-valid-radio">
          <label>
            <%= f.radio_button :is_valid, true %>
            <span class="admin-badge admin-badge--valid">有効</span>
          </label>
          <label>
            <%= f.radio_button :is_valid, false %>
            <span class="admin-badge admin-badge--invalid">退会</span>
          </label>
        </div>
      </div>

      <div class="d-grid mt-2">
        <%= f.submit "変更を保存", class: "btn admin-auth-submit-btn" %>
      </div>

    <% end %>

    <hr class="auth-divider my-4">
    <div class="text-center">
      <%= link_to admin_customer_path(@customer), class: "btn auth-register-btn" do %>
        <i class="fas fa-arrow-left me-1"></i>詳細に戻る
      <% end %>
    </div>

  </div>
</div>
