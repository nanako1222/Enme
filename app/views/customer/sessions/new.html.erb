<div class="container">
  <div class="col-11 col-md-8 mx-auto">

    <div class="text-center mt-5">
      <h4 class="text-center"><strong>ログイン</strong></h4>
    </div>

    <% if flash[:alert] %>
      <%= alert %>
    <% end %>

    <h6 class="text-center mt-4" style="background-color: transparent;">会員の方はこちらからログイン</h6>

    <%= form_with model: @customer, url: customer_session_path, id: 'in_customer', class: 'in_customer', local: true do |f| %>
      <%= render "customer/shared/error_messages", resource: resource %>

      <div class="row mt-3 align-items-center">
        <%= f.label :email, class: "col-md-4" %>
        <%= f.email_field :email, autofocus: true, autocomplete: "メールアドレス", class: "col-md-8" %>
      </div>

      <div class="row mt-3 align-items-center">
        <%= f.label :password, class: "col-md-4" %>
        <%= f.password_field :password, autocomplete: "パスワード", class: "col-md-8" %>
      </div>

      <div class="mt-4 text-center">
        <%= button_tag type: :submit, class: "btn btn-success active" do %>
          <i class="fas fa-sign-in-alt"></i> ログイン
        <% end %>
      </div>

      <div class="text-center mt-5 mb-4">
        <h6 class="text-center">会員登録がお済みでない方</h6>
        <p class="mt-3">
          <%= link_to "こちら", new_customer_registration_path, class: "btn btn-outline-info btn-sm", data: {"turbolinks": false} %>
          から新規登録を行ってください。
        </p>
      </div>

    <% end %>

  </div>
</div>
