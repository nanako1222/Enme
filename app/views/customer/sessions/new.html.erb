<%# ─── ヒーロー ─────────────────────────────── %>
<div class="auth-hero">
  <div class="container text-center py-4">
    <h1 class="auth-hero__title">会員ログイン</h1>
    <p class="auth-hero__sub">アレルゲン情報の保存やお気に入り登録をご利用いただけます</p>
  </div>
</div>

<div class="container py-5">
  <div class="auth-card mx-auto">

    <%= form_with model: @customer, url: customer_session_path, local: true do |f| %>
      <%= render "customer/shared/error_messages", resource: resource %>

      <div class="mb-4">
        <%= f.label :email, "メールアドレス", class: "auth-form__label" %>
        <%= f.email_field :email, autofocus: true, autocomplete: "email",
            class: "form-control auth-form__input" %>
      </div>

      <div class="mb-4">
        <%= f.label :password, "パスワード", class: "auth-form__label" %>
        <%= f.password_field :password, autocomplete: "current-password",
            class: "form-control auth-form__input" %>
      </div>

      <div class="d-grid mt-2">
        <%= button_tag type: :submit, class: "btn auth-submit-btn" do %>
          <i class="fas fa-sign-in-alt me-1"></i>ログイン
        <% end %>
      </div>
    <% end %>

    <hr class="auth-divider my-4">

    <p class="text-center auth-sub-text">会員登録がお済みでない方</p>
    <div class="text-center">
      <%= link_to new_customer_registration_path, class: "btn auth-register-btn",
          data: {"turbolinks": false} do %>
        新規会員登録はこちら
      <% end %>
    </div>

  </div>
</div>
