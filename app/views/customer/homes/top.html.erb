<%# ─── Hero ─────────────────────────────────────────────── %>
<section class="top-hero">
  <div class="container">
    <div class="row align-items-center g-5 pt-5 pb-3">
      <div class="col-lg-6">
        <p class="top-hero__label">アレルギー対応飲食店検索サービス</p>
        <h1 class="top-hero__title">アレルギーがあっても、<br>安心して外食を。</h1>
        <p class="top-hero__desc mt-3">
          登録したアレルゲンに合わせて、対応している飲食店を検索できます。
        </p>

        <p class="top-hero__steps-label mt-4">Enmeの使い方</p>
        <div class="top-hero__steps">
          <div class="top-hero__step-item">
            <div class="top-hero__step-num">1</div>
            <%= image_tag "step-signup.svg", class: "top-hero__step-icon", alt: "" %>
            <span class="top-hero__step-label">会員登録</span>
          </div>
          <div class="top-hero__step-item">
            <div class="top-hero__step-num">2</div>
            <%= image_tag "step-allergen.svg", class: "top-hero__step-icon", alt: "" %>
            <span class="top-hero__step-label">アレルゲン登録</span>
          </div>
          <div class="top-hero__step-item">
            <div class="top-hero__step-num">3</div>
            <%= image_tag "step-search.svg", class: "top-hero__step-icon", alt: "" %>
            <span class="top-hero__step-label">お店を検索</span>
          </div>
          <div class="top-hero__step-item">
            <div class="top-hero__step-num">4</div>
            <%= image_tag "step-dining.svg", class: "top-hero__step-icon", alt: "" %>
            <span class="top-hero__step-label">安心して外食</span>
          </div>
        </div>
      </div>

      <div class="col-lg-6">
        <div class="top-hero__img-wrap">
          <%= image_tag "top.jpg", class: "top-hero__img", alt: "食卓風景" %>
        </div>
      </div>
    </div>
  </div>
</section>

<%# ─── Search ─────────────────────────────────────────── %>
<section class="top-search">
  <div class="container">
    <div class="top-search__card">
      <h2 class="top-search__card-title">
        <i class="fas fa-search me-2"></i>飲食店を検索する
      </h2>

    <%= form_with model: @customer, url: restaurants_path, method: :get,
                  id: "search_restaurant", local: true do |f| %>

      <%# アレルゲン選択 %>
      <div class="mb-4">
        <p class="top-search__label">
          <i class="fas fa-exclamation-triangle me-1"></i>除外するアレルゲン
        </p>

        <%# アレルゲン折り畳みトグル（PC・スマホ共通） %>
        <button type="button"
                class="btn btn-outline-secondary mb-2"
                data-bs-toggle="collapse"
                data-bs-target="#allergenArea"
                aria-expanded="false">
          <i class="fas fa-filter me-1"></i>アレルゲンで絞り込む
          <span id="allergenBadge" class="badge bg-brown ms-1 d-none">0</span>
        </button>

        <%# チェックボックス本体（デフォルト非表示） %>
        <div id="allergenArea" class="top-allergen-area collapse">
          <div class="allergen-pills">
            <%= f.collection_check_boxes(
                  :allergies, @allergies, :id, :allergen,
                  include_hidden: false
                ) do |a| %>
              <%= a.label { a.check_box + a.text } %>
            <% end %>
          </div>
        </div>
      </div>

      <%# 都道府県・エリア・検索ボタン %>
      <div class="row g-3 align-items-end">
        <div class="col-md-4">
          <label class="top-search__label">都道府県</label>
          <%= f.collection_select :state_id, State.all, :id, :state,
              { include_blank: "すべての都道府県" },
              { class: "search-select w-100" } %>
        </div>
        <div class="col-md-4">
          <label class="top-search__label">エリア</label>
          <div id="areas_select_search">
            <select name="customer[area_id]" id="customer_area_id" class="search-select w-100">
              <option value="">すべてのエリア</option>
            </select>
          </div>
        </div>
        <div class="col-md-4">
          <%= button_tag type: :submit, class: "btn top-search__btn w-100" do %>
            <i class="fas fa-search me-1"></i>検索する
          <% end %>
        </div>
      </div>
      <p class="search-form-area-note mt-2">
        ※エリア区分の詳細は
        <%= link_to "こちら", about_path, class: "search-form-area-link", data: {"turbolinks" => false} %>
        をご覧ください
      </p>

    <% end %>
    </div><%# /top-search__card %>
  </div>
</section>

<%# ─── New Restaurants ───────────────────────────────── %>
<section class="top-restaurants">
  <div class="container">
    <h2 class="top-section-title">新着店舗</h2>
    <p class="top-section-sub">アレルギー対応の飲食店をご紹介します</p>

    <div class="row g-4">
      <% @restaurants.each do |restaurant| %>
        <div class="col-md-4">
          <div class="top-card">
            <%= link_to restaurant_path(restaurant), class: "text-decoration-none" do %>
              <div class="top-card__img-wrap">
                <%= image_tag restaurant.get_image(400, 230),
                    class: "top-card__img",
                    alt: restaurant.name %>
              </div>
              <div class="top-card__body">
                <h5 class="top-card__name"><%= restaurant.name %></h5>
                <p class="top-card__area">
                  <i class="fas fa-map-marker-alt me-1"></i>
                  <%= restaurant.state.state %>&nbsp;<%= restaurant.area.area %>
                </p>
              </div>
            <% end %>
          </div>
        </div>
      <% end %>
    </div>
  </div>
</section>
