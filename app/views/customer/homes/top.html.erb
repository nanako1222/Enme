<%# ─── Hero ─────────────────────────────────────────────── %>
<section class="top-hero">
  <div class="container">
    <div class="row align-items-center g-5 py-5">
      <div class="col-lg-6">
        <p class="top-hero__label">アレルギー対応飲食店検索サービス</p>
        <h1 class="top-hero__title">アレルギーがあっても、<br>安心して外食を。</h1>
        <p class="top-hero__desc mt-3">
          登録したアレルゲンに合わせて、対応している飲食店を検索できます。
        </p>
        <div class="top-hero__features mt-4">
          <div class="top-hero__feature">
            <i class="fas fa-shield-alt top-hero__feature-icon"></i>
            <span>アレルゲンを除いた<br>お店だけ表示</span>
          </div>
          <div class="top-hero__feature">
            <i class="fas fa-map-marker-alt top-hero__feature-icon"></i>
            <span>エリアや都道府県<br>で絞り込み</span>
          </div>
          <div class="top-hero__feature">
            <i class="fas fa-users top-hero__feature-icon"></i>
            <span>家族と一緒に<br>安心して外食</span>
          </div>
        </div>
      </div>
      <div class="col-lg-6">
        <%= image_tag "top.jpg", class: "top-hero__img img-fluid rounded-4", alt: "食卓風景" %>
      </div>
    </div>
  </div>
</section>

<%# ─── Search ─────────────────────────────────────────── %>
<section class="top-search">
  <div class="container">
    <h2 class="top-section-title">飲食店を検索する</h2>

    <%= form_with model: @customer, url: restaurants_path, method: :get,
                  id: "search_restaurant", local: true do |f| %>

      <%# アレルゲン選択 %>
      <div class="mb-4">
        <p class="top-search__label">
          <i class="fas fa-exclamation-triangle me-1"></i>除外するアレルゲン
        </p>

        <%# アレルゲン折り畳みトグル（PC・スマホ共通） %>
        <button type="button"
                class="btn btn-outline-secondary mb-2"
                data-bs-toggle="collapse"
                data-bs-target="#allergenArea"
                aria-expanded="false">
          <i class="fas fa-filter me-1"></i>アレルゲンで絞り込む
          <span id="allergenBadge" class="badge bg-brown ms-1 d-none">0</span>
        </button>

        <%# チェックボックス本体（デフォルト非表示） %>
        <div id="allergenArea" class="top-allergen-area collapse">
          <div class="top-allergen-grid">
            <%= f.collection_check_boxes(
                  :allergies, @allergies, :id, :allergen,
                  include_hidden: false
                ) do |a| %>
              <label class="top-allergen-chip">
                <%= a.check_box class: "top-allergen-cb" %><%= a.text %>
              </label>
            <% end %>
          </div>
        </div>
      </div>

      <%# 都道府県・エリア・検索ボタン %>
      <div class="row g-3 align-items-end">
        <div class="col-md-4">
          <label class="top-search__label">都道府県</label>
          <%= f.collection_select :state_id, State.all, :id, :state,
              { include_blank: "すべての都道府県" },
              { class: "form-select" } %>
        </div>
        <div class="col-md-4">
          <label class="top-search__label">エリア</label>
          <div id="areas_select_search">
            <select name="customer[area_id]" id="customer_area_id" class="form-select">
              <option value="">すべてのエリア</option>
            </select>
          </div>
        </div>
        <div class="col-md-4">
          <%= button_tag type: :submit, class: "btn top-search__btn w-100" do %>
            <i class="fas fa-search me-1"></i>検索する
          <% end %>
        </div>
      </div>

    <% end %>
  </div>
</section>

<%# ─── New Restaurants ───────────────────────────────── %>
<section class="top-restaurants">
  <div class="container">
    <h2 class="top-section-title">新着店舗</h2>
    <p class="top-section-sub">アレルギー対応の飲食店をご紹介します</p>

    <div class="row g-4">
      <% @restaurants.each do |restaurant| %>
        <div class="col-md-4">
          <div class="top-card">
            <%= link_to restaurant_path(restaurant), class: "text-decoration-none" do %>
              <div class="top-card__img-wrap">
                <%= image_tag restaurant.get_image(400, 230),
                    class: "top-card__img",
                    alt: restaurant.name %>
              </div>
              <div class="top-card__body">
                <h5 class="top-card__name"><%= restaurant.name %></h5>
                <p class="top-card__area">
                  <i class="fas fa-map-marker-alt me-1"></i>
                  <%= restaurant.state.state %>&nbsp;<%= restaurant.area.area %>
                </p>
                <% allergens = restaurant.menus.flat_map(&:allergies).map(&:allergen).uniq %>
                <div class="top-card__tags">
                  <% if allergens.any? %>
                    <% allergens.first(4).each do |a| %>
                      <span class="top-card__tag"><%= a %>対応</span>
                    <% end %>
                    <% if allergens.size > 4 %>
                      <span class="top-card__tag top-card__tag--more">+<%= allergens.size - 4 %></span>
                    <% end %>
                  <% else %>
                    <span class="top-card__no-tag">アレルゲン情報を確認</span>
                  <% end %>
                </div>
              </div>
            <% end %>
          </div>
        </div>
      <% end %>
    </div>
  </div>
</section>

<%# ─── How to Use ─────────────────────────────────────── %>
<section class="top-steps">
  <div class="container">
    <h2 class="top-section-title">Enmeの使い方</h2>
    <p class="top-section-sub">かんたん4ステップで、安心して外食を楽しもう</p>

    <div class="row g-4 text-center justify-content-center">
      <div class="col-6 col-md-3">
        <div class="top-step">
          <div class="top-step__icon-wrap">
            <span class="top-step__num">1</span>
            <i class="fas fa-user-plus top-step__icon"></i>
          </div>
          <p class="top-step__title">会員登録</p>
          <p class="top-step__desc">無料で登録できます</p>
        </div>
      </div>
      <div class="col-6 col-md-3">
        <div class="top-step">
          <div class="top-step__icon-wrap">
            <span class="top-step__num">2</span>
            <i class="fas fa-clipboard-list top-step__icon"></i>
          </div>
          <p class="top-step__title">アレルゲンを登録</p>
          <p class="top-step__desc">食べられない食材を登録</p>
        </div>
      </div>
      <div class="col-6 col-md-3">
        <div class="top-step">
          <div class="top-step__icon-wrap">
            <span class="top-step__num">3</span>
            <i class="fas fa-search top-step__icon"></i>
          </div>
          <p class="top-step__title">お店を検索</p>
          <p class="top-step__desc">アレルゲンで自動絞り込み</p>
        </div>
      </div>
      <div class="col-6 col-md-3">
        <div class="top-step">
          <div class="top-step__icon-wrap">
            <span class="top-step__num">4</span>
            <i class="fas fa-utensils top-step__icon"></i>
          </div>
          <p class="top-step__title">安心して外食</p>
          <p class="top-step__desc">メニューも事前に確認</p>
        </div>
      </div>
    </div>

    <div class="text-center mt-5">
      <%= link_to new_customer_registration_path, class: "btn top-steps__cta", data: {"turbolinks": false} do %>
        無料で会員登録する <i class="fas fa-arrow-right ms-1"></i>
      <% end %>
    </div>
  </div>
</section>
