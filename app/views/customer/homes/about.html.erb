<%# ─── ヒーロー ─────────────────────────────── %>
<div class="about-hero">
  <div class="container text-center py-5">
    <h1 class="about-hero__title">Enmeについて</h1>
    <p class="about-hero__sub">アレルギーがあっても、安心して外食を。</p>
  </div>
</div>

<%# ─── このサイトについて ──────────────────── %>
<section class="about-section">
  <div class="container">
    <div class="about-card">
      <div class="row g-4 g-lg-5 align-items-center">
        <div class="col-md-6">
          <h2 class="about-section__title">
            <i class="fas fa-info-circle me-2"></i>このサイトについて
          </h2>
          <p class="about-section__text mt-3">
            Enme（エンミー）は、食物アレルギーをお持ちの方が安心して外食を楽しめるよう、アレルゲン対応の飲食店を探せるサービスです。除外したいアレルゲンやエリアを選ぶだけで、条件に合ったお店を見つけられます。
          </p>
          <p class="about-section__text">
            会員登録なしでもご利用いただけます。登録すると、アレルゲン情報の保存やお気に入りの飲食店登録など、より便利にお使いいただけます。
          </p>
          <% unless customer_signed_in? %>
            <div class="mt-4">
              <%= link_to new_customer_registration_path, class: "btn about-cta-btn me-2" do %>
                <i class="fas fa-user-plus me-1"></i>新規会員登録
              <% end %>
              <%= link_to new_customer_session_path, class: "btn about-sub-btn" do %>
                ログイン
              <% end %>
            </div>
          <% end %>
        </div>
        <div class="col-md-6">
          <%= image_tag 'about_image.jpg',
              class: "about-hero-img img-fluid",
              alt: "Enmeサービスイメージ" %>
        </div>
      </div>
    </div>
  </div>
</section>

<%# ─── 地域エリアについて ─────────────────── %>
<section class="about-section about-section--beige">
  <div class="container">
    <h2 class="about-section__title text-center mb-2">
      <i class="fas fa-map-marked-alt me-2"></i>地域エリアについて
    </h2>
    <p class="about-section__text text-center mb-4">
      都道府県ごとに地域エリアを分けており、店舗を絞り込む際に活用します。<br>
      各マップをクリックすると拡大表示できます。
    </p>

    <div class="row g-3 justify-content-center">
      <% [
        { file: 'osaka.jpg',     name: '大阪府' },
        { file: 'kyoto.jpg',     name: '京都府' },
        { file: 'hyogo.jpg',     name: '兵庫県' },
        { file: 'nara.jpg',      name: '奈良県' },
        { file: 'wakayama.jpg',  name: '和歌山県' },
        { file: 'shiga.jpg',     name: '滋賀県' },
      ].each do |map| %>
        <div class="col-6 col-md-4">
          <div class="about-map-item"
               data-bs-toggle="modal"
               data-bs-target="#mapModal"
               data-src="<%= asset_path(map[:file]) %>"
               data-title="<%= map[:name] %>の地域エリア">
            <%= image_tag map[:file],
                class: "about-map-img",
                alt: "#{map[:name]}の地域エリアマップ" %>
            <div class="about-map-overlay">
              <i class="fas fa-search-plus"></i>
            </div>
            <p class="about-map-name"><%= map[:name] %></p>
          </div>
        </div>
      <% end %>
    </div>
  </div>
</section>

<%# ─── 飲食店経営者の皆様へ ─────────────── %>
<section class="about-section">
  <div class="container">
    <div class="about-owner-card">
      <div class="row g-4 align-items-center">
        <div class="col-md-8">
          <h2 class="about-section__title about-section__title--light">
            <i class="fas fa-store me-2"></i>飲食店経営者の皆様へ
          </h2>
          <p class="about-section__text about-section__text--light mt-3">
            飲食店経営者の皆様のご協力が、食物アレルギーをお持ちの方々の「安心して行けるお店」を増やす力になります。
          </p>
          <p class="about-section__text about-section__text--light">
            アレルゲン情報を公開することで、外食の選択肢が少ない方々に、大切な一軒を届けることができます。ぜひEnmeへのご登録をお願いいたします。
          </p>
        </div>
        <div class="col-md-4 text-center text-md-end">
          <%= link_to new_restaurant_registration_path, class: "btn about-owner-btn" do %>
            <i class="fas fa-store-alt me-1"></i>店舗登録はこちら
          <% end %>
        </div>
      </div>
    </div>
  </div>
</section>

<%# ─── 地図拡大モーダル ───────────────────── %>
<div class="modal fade" id="mapModal" tabindex="-1" aria-hidden="true">
  <div class="modal-dialog modal-lg modal-dialog-centered">
    <div class="modal-content about-modal">
      <div class="modal-header about-modal__header">
        <h5 class="modal-title about-modal__title" id="mapModalTitle"></h5>
        <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="閉じる"></button>
      </div>
      <div class="modal-body p-0">
        <img id="mapModalImg" src="" alt="" class="img-fluid w-100">
      </div>
    </div>
  </div>
</div>

<script>
  document.addEventListener('DOMContentLoaded', function() {
    const modal = document.getElementById('mapModal');
    if (!modal) return;
    modal.addEventListener('show.bs.modal', function(e) {
      const trigger = e.relatedTarget;
      document.getElementById('mapModalTitle').textContent = trigger.dataset.title || '';
      document.getElementById('mapModalImg').src = trigger.dataset.src || '';
    });
  });
</script>
