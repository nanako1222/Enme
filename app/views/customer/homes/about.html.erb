  document.addEventListener('DOMContentLoaded', function() {
    // ─── エリア検索 ─────────────────────────────
    const searchInput = document.getElementById('areaSearchInput');
    const searchResult = document.getElementById('areaSearchResult');
    const notFound = document.getElementById('areaSearchNotFound');

    if (searchInput) {
      searchInput.addEventListener('input', function() {
        const q = this.value.trim();
        searchResult.classList.add('d-none');
        notFound.classList.add('d-none');
        if (!q) return;

        const matches = Object.entries(CITY_AREA_MAP).filter(([city]) => city.includes(q));
        if (matches.length > 0) {
          searchResult.innerHTML = matches.map(([city, area]) =>
            `<span class="about-area-match"><strong>${city}</strong><span class="about-area-match__arrow">→</span>${area}</span>`
          ).join('');
          searchResult.classList.remove('d-none');
        } else if (q.length >= 2) {
          notFound.classList.remove('d-none');
        }
      });
    }

    // ─── 地図モーダル ────────────────────────────
    const modal = document.getElementById('mapModal');
    if (!modal) return;
    modal.addEventListener('show.bs.modal', function(e) {
      const trigger = e.relatedTarget;
      document.getElementById('mapModalTitle').textContent = trigger.dataset.title || '';
      document.getElementById('mapModalImg').src = trigger.dataset.src || '';
    });
  });
