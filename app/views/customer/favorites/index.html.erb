<%# ─── 上部お知らせ帯 ──────────────────────── %>
<div class="rest-notice-band">
  <div class="container">
    <p class="rest-notice-band__demo">
      <i class="fas fa-info-circle me-1"></i>現在登録されているデータは架空のサンプルデータです。
    </p>
  </div>
</div>

<%# ─── ページヘッダー ─────────────────────── %>
<div class="menu-list-header">
  <div class="container py-4">
    <div class="d-flex align-items-center justify-content-between flex-wrap gap-3">
      <div>
        <h1 class="menu-list-header__title">
          <i class="fas fa-star me-2"></i>お気に入り
        </h1>
        <p class="menu-list-header__count">全 <strong><%= @favorites_count %></strong> 件</p>
      </div>
      <%= link_to search_restaurants_path, class: "btn menu-back-btn" do %>
        <i class="fas fa-search me-1"></i>飲食店を検索
      <% end %>
    </div>
  </div>
</div>

<%# ─── カード一覧 ─────────────────────────── %>
<div class="container py-4 pb-5">
  <% if @favorites.any? %>
    <div class="row g-4">
      <% @favorites.each do |favorite| %>
        <div class="col-md-6 col-lg-3">
          <div class="top-card search-card">

            <%= link_to restaurant_path(favorite.restaurant), class: "text-decoration-none d-block" do %>
              <div class="top-card__img-wrap">
                <%= image_tag(
                  favorite.restaurant.image.attached? ? favorite.restaurant.get_image(400, 230) : 'default-image.jpg',
                  class: "top-card__img", alt: favorite.restaurant.name
                ) %>
              </div>
            <% end %>

            <div class="top-card__body search-card__body">
              <h5 class="top-card__name"><%= favorite.restaurant.name %></h5>
              <p class="top-card__area">
                <i class="fas fa-map-marker-alt me-1"></i>
                <%= favorite.restaurant.state.state %>&nbsp;<%= favorite.restaurant.area.area %>
              </p>
              <% if favorite.restaurant.regular_holiday.present? %>
                <p class="search-card__holiday">
                  <i class="fas fa-calendar-times me-1"></i>定休日：<%= favorite.restaurant.regular_holiday %>
                </p>
              <% end %>
              <%= link_to restaurant_path(favorite.restaurant), class: "search-card__link-btn" do %>
                詳細を見る&nbsp;<i class="fas fa-arrow-right"></i>
              <% end %>
            </div>

          </div>
        </div>
      <% end %>
    </div>

    <div class="d-flex justify-content-center mt-5 mb-2">
      <%= paginate @favorites %>
    </div>

  <% else %>
    <div class="text-center py-5">
      <div class="search-empty-icon mb-4">
        <i class="fas fa-star"></i>
      </div>
      <h5 class="search-empty-title">まだお気に入りに追加されたお店はありません</h5>
      <p class="text-muted small mt-2">飲食店の詳細ページからお気に入りに追加できます</p>
      <%= link_to search_restaurants_path, class: "btn search-empty-btn mt-3" do %>
        <i class="fas fa-search me-1"></i>飲食店を探す
      <% end %>
    </div>
  <% end %>
</div>
