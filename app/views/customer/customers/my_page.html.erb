<div class="container">
  <div class="col-11 col-md-8 mx-auto">

    <h4 class="text-center mt-5">会員情報詳細</h4>

    <div class="flashing mt-2">
      <p>※現在登録されているデータは架空です</p>
    </div>
    <div class="mt-3">
      <% if flash[:notice] %>
        <%= notice %>
      <% end %>
    </div>

    <div class="d-flex align-items-center gap-3 mt-4">
      <h5 class="mb-0">登録情報</h5>
      <%= link_to customers_information_edit_path, class: "btn btn-success active btn-sm" do %>
        <i class="fas fa-user-edit"></i> 編集する
      <% end %>
    </div>

    <div class="table-responsive mt-3">
      <table class="table table-hover">
        <tr>
          <th>氏名</th>
          <td><%= @customer.full_name %></td>
        </tr>
        <tr>
          <th>カナ</th>
          <td><%= @customer.full_name_kana %></td>
        </tr>
        <tr>
          <th>メールアドレス</th>
          <td><%= @customer.email %></td>
        </tr>
        <tr>
          <th>都道府県</th>
          <td><%= @state %></td>
        </tr>
        <tr>
          <th>地域エリア</th>
          <td><%= @area %></td>
        </tr>
        <tr>
          <th>電話番号</th>
          <td><%= @customer.telephone_number %></td>
        </tr>
        <tr>
          <th>アレルギー</th>
          <td>
            <% @customer.allergies.each do |allergy| %>
              <span class="badge bg-secondary me-1"><%= allergy.allergen %></span>
            <% end %>
          </td>
        </tr>
      </table>
    </div>

  </div>
</div>
