<%# ─── 上部お知らせ帯 ──────────────────────── %>
<div class="rest-notice-band">
  <div class="container">
    <p class="rest-notice-band__demo">
      <i class="fas fa-info-circle me-1"></i>現在登録されているデータは架空のサンプルデータです。
    </p>
  </div>
</div>

<%# ─── ページヘッダー ─────────────────────── %>
<div class="menu-list-header">
  <div class="container py-4">
    <div class="d-flex align-items-center justify-content-between flex-wrap gap-3">
      <h1 class="menu-list-header__title">
        <i class="fas fa-user-circle me-2"></i>マイページ
      </h1>
      <%= link_to customers_information_edit_path, class: "btn menu-back-btn" do %>
        <i class="fas fa-user-edit me-1"></i>情報を編集
      <% end %>
    </div>
  </div>
</div>

<%# ─── 情報カード ──────────────────────────── %>
<div class="container py-4 pb-5">
  <div class="mypage-card">

    <%# 基本情報 %>
    <h2 class="mypage-card__section-title">
      <i class="fas fa-id-card me-2"></i>登録情報
    </h2>
    <dl class="mypage-dl">
      <div class="mypage-dl__row">
        <dt class="mypage-dl__label">氏名</dt>
        <dd class="mypage-dl__value"><%= @customer.full_name %></dd>
      </div>
      <div class="mypage-dl__row">
        <dt class="mypage-dl__label">フリガナ</dt>
        <dd class="mypage-dl__value"><%= @customer.full_name_kana %></dd>
      </div>
      <div class="mypage-dl__row">
        <dt class="mypage-dl__label">メールアドレス</dt>
        <dd class="mypage-dl__value"><%= @customer.email %></dd>
      </div>
      <div class="mypage-dl__row">
        <dt class="mypage-dl__label">都道府県</dt>
        <dd class="mypage-dl__value"><%= @state %></dd>
      </div>
      <div class="mypage-dl__row">
        <dt class="mypage-dl__label">地域エリア</dt>
        <dd class="mypage-dl__value"><%= @area %></dd>
      </div>
      <div class="mypage-dl__row">
        <dt class="mypage-dl__label">電話番号</dt>
        <dd class="mypage-dl__value"><%= @customer.telephone_number %></dd>
      </div>
    </dl>

    <%# アレルゲン %>
    <h2 class="mypage-card__section-title mt-4">
      <i class="fas fa-exclamation-triangle me-2"></i>登録済みアレルゲン
    </h2>
    <% if @customer.allergies.any? %>
      <div class="d-flex flex-wrap gap-2 mt-3">
        <% @customer.allergies.each do |allergy| %>
          <span class="menu-allergen-tag menu-allergen-tag--lg"><%= allergy.allergen %></span>
        <% end %>
      </div>
    <% else %>
      <p class="mypage-no-allergen mt-3">アレルゲンは登録されていません</p>
    <% end %>

  </div>
</div>
