<% if flash[:notice] %>
  <div class="container pt-4">
    <div class="alert alert-success alert-dismissible fade show border-0 rounded-3" role="alert">
      <%= flash[:notice] %>
      <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
  </div>
<% end %>

<%# ─── 店舗ヘッダー ──────────────────────────────────── %>
<div class="rest-hero">
  <div class="container py-5">
    <div class="row g-4 g-lg-5 align-items-start">

      <%# 写真 %>
      <div class="col-lg-5">
        <div class="rest-hero__img-wrap">
          <% if @restaurant.image.attached? %>
            <%= image_tag @restaurant.get_image(600, 400),
                class: "rest-hero__img", alt: @restaurant.name %>
          <% else %>
            <%= image_tag 'default-image.jpg',
                class: "rest-hero__img", alt: @restaurant.name %>
          <% end %>
          <span class="rest-hero__demo-badge">※架空データ</span>
        </div>
      </div>

      <%# 店舗名・クイック情報 %>
      <div class="col-lg-7">
        <p class="rest-hero__location">
          <i class="fas fa-map-marker-alt me-1"></i><%= @state %>&nbsp;<%= @area %>
        </p>
        <h1 class="rest-hero__name"><%= @restaurant.name %></h1>

        <div class="rest-hero__quickinfo mt-3">
          <% if @restaurant.business_hours.present? %>
            <div class="rest-hero__qi-item">
              <i class="fas fa-clock"></i>
              <span><%= @restaurant.business_hours %></span>
            </div>
          <% end %>
          <% if @restaurant.regular_holiday.present? %>
            <div class="rest-hero__qi-item">
              <i class="fas fa-calendar-times"></i>
              <span>定休日：<%= @restaurant.regular_holiday %></span>
            </div>
          <% end %>
        </div>

        <% if @restaurant.introduction.present? %>
          <div class="rest-hero__intro mt-4">
            <%= simple_format(@restaurant.introduction) %>
          </div>
        <% end %>

        <%# アクションボタン %>
        <div class="d-flex flex-wrap gap-3 mt-4">
          <% if customer_signed_in? %>
            <%= render 'customer/favorites/favorite', favorite: @favorite %>
          <% end %>
          <%= link_to restaurant_menus_path(@restaurant.id), class: "btn rest-hero__menu-btn" do %>
            <i class="fas fa-clipboard-list me-1"></i>メニュー一覧
          <% end %>
        </div>
      </div>

    </div>
  </div>
</div>

<%# ─── アレルゲン対応 ─────────────────────────────── %>
<% allergens = @restaurant.menus.flat_map(&:allergies).map(&:allergen).uniq %>
<% if allergens.any? %>
  <section class="rest-allergen">
    <div class="container py-4">
      <h2 class="rest-section-title">
        <i class="fas fa-shield-alt me-2"></i>アレルゲン対応情報
      </h2>
      <p class="rest-section-sub">この店舗のメニューで対応しているアレルゲンです</p>
      <div class="rest-allergen-tags">
        <% allergens.each do |allergen| %>
          <span class="rest-allergen-tag"><%= allergen %>対応</span>
        <% end %>
      </div>
    </div>
  </section>
<% end %>

<%# ─── お知らせ・新着情報 ──────────────────────────── %>
<section class="rest-news">
  <div class="container py-4">
    <h2 class="rest-section-title">
      <i class="fas fa-bullhorn me-2"></i>お知らせ・新着情報
    </h2>
    <p class="rest-section-sub">期間限定メニュー・アレルギー対応メニュー追加・営業時間変更など</p>

    <% if @restaurant.news.present? %>
      <div class="rest-news-card">
        <div class="rest-news-card__icon">
          <i class="fas fa-store"></i>
        </div>
        <div class="rest-news-card__body">
          <p class="rest-news-card__from">店舗からのお知らせ</p>
          <div class="rest-news-card__text">
            <%= simple_format(@restaurant.news) %>
          </div>
        </div>
      </div>
    <% else %>
      <div class="rest-news-empty">
        <i class="fas fa-bell rest-news-empty__icon"></i>
        <p class="rest-news-empty__text">現在、新着のお知らせはありません</p>
        <p class="rest-news-empty__sub">期間限定メニューや営業時間変更などが出た際にこちらへ掲載されます</p>
      </div>
    <% end %>
  </div>
</section>

<%# ─── 店舗基本情報 ──────────────────────────────── %>
<section class="rest-info">
  <div class="container py-4 pb-5">
    <h2 class="rest-section-title">
      <i class="fas fa-store me-2"></i>店舗情報
    </h2>

    <div class="rest-info-card mt-3">

      <div class="rest-info-row">
        <div class="rest-info-row__icon"><i class="fas fa-map-marker-alt"></i></div>
        <div>
          <p class="rest-info-row__label">住所</p>
          <p class="rest-info-row__value"><%= @state %>&nbsp;<%= @area %>&nbsp;<%= @restaurant.address %></p>
        </div>
      </div>

      <% if @restaurant.telephone_number.present? %>
        <div class="rest-info-row">
          <div class="rest-info-row__icon"><i class="fas fa-phone-alt"></i></div>
          <div>
            <p class="rest-info-row__label">電話番号</p>
            <p class="rest-info-row__value"><%= @restaurant.telephone_number %></p>
          </div>
        </div>
      <% end %>

      <% if @restaurant.email.present? %>
        <div class="rest-info-row">
          <div class="rest-info-row__icon"><i class="fas fa-envelope"></i></div>
          <div>
            <p class="rest-info-row__label">メールアドレス</p>
            <p class="rest-info-row__value"><%= @restaurant.email %></p>
          </div>
        </div>
      <% end %>

      <% if @restaurant.home_page.present? %>
        <div class="rest-info-row">
          <div class="rest-info-row__icon"><i class="fas fa-globe"></i></div>
          <div>
            <p class="rest-info-row__label">ホームページ</p>
            <p class="rest-info-row__value">
              <%= link_to @restaurant.home_page, @restaurant.home_page,
                  target: "_blank", rel: "noopener", class: "rest-info-link" %>
            </p>
          </div>
        </div>
      <% end %>

      <% if @restaurant.parking.present? %>
        <div class="rest-info-row">
          <div class="rest-info-row__icon"><i class="fas fa-parking"></i></div>
          <div>
            <p class="rest-info-row__label">駐車場</p>
            <p class="rest-info-row__value"><%= @restaurant.parking %></p>
          </div>
        </div>
      <% end %>

      <% if @restaurant.business_hours.present? %>
        <div class="rest-info-row">
          <div class="rest-info-row__icon"><i class="fas fa-clock"></i></div>
          <div>
            <p class="rest-info-row__label">営業時間</p>
            <p class="rest-info-row__value"><%= @restaurant.business_hours %></p>
          </div>
        </div>
      <% end %>

      <% if @restaurant.regular_holiday.present? %>
        <div class="rest-info-row">
          <div class="rest-info-row__icon"><i class="fas fa-calendar-times"></i></div>
          <div>
            <p class="rest-info-row__label">定休日</p>
            <p class="rest-info-row__value"><%= @restaurant.regular_holiday %></p>
          </div>
        </div>
      <% end %>

    </div>
  </div>
</section>

<%# ─── メニューへのCTA ──────────────────────────── %>
<section class="rest-cta">
  <div class="container text-center py-5">
    <p class="rest-cta__lead">メニューでアレルゲン詳細を確認しましょう</p>
    <%= link_to restaurant_menus_path(@restaurant.id), class: "btn rest-cta__btn" do %>
      <i class="fas fa-clipboard-list me-2"></i>この店舗のメニューを見る
    <% end %>
  </div>
</section>
