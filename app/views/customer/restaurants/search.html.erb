<%# ─── ヒーロー ─────────────────────────────── %>
<div class="search-form-hero">
  <div class="container text-center py-4">
    <h1 class="search-form-hero__title">飲食店を検索する</h1>
    <p class="search-form-hero__sub">除外したいアレルゲンとエリアを選んで、安心して食べられるお店を見つけましょう</p>
  </div>
</div>

<%# ─── フォームカード ──────────────────────── %>
<div class="container py-5">
  <div class="search-form-card">

    <%= form_with model: @customer, url: restaurants_path, method: :get,
        id: 'search_restaurant', class: 'search_restaurant', local: true do |f| %>

      <%# アレルゲン選択 %>
      <div class="mb-4">
        <p class="top-search__label">
          <i class="fas fa-exclamation-triangle me-1"></i>除外するアレルゲン
        </p>

        <button type="button"
                class="btn btn-outline-secondary mb-2"
                data-bs-toggle="collapse"
                data-bs-target="#allergenArea"
                aria-expanded="false">
          <i class="fas fa-filter me-1"></i>アレルゲンで絞り込む
          <span id="allergenBadge" class="badge bg-brown ms-1 d-none">0</span>
        </button>

        <%# 選択中チップ表示 %>
        <div id="allergenChipWrap" class="allergen-chip-summary d-none">
          <span class="allergen-chip-summary__label">除外中：</span>
          <div id="allergenChipList" class="allergen-chip-summary__list"></div>
        </div>

        <div id="allergenArea" class="top-allergen-area collapse">
          <div class="allergen-pills">
            <%= f.collection_check_boxes(:allergies, @allergies, :id, :allergen, include_hidden: false) do |a| %>
              <%= a.label { a.check_box + a.text } %>
            <% end %>
          </div>
        </div>
      </div>

      <%# エリア絞り込み＋検索ボタン %>
      <div class="row g-3 align-items-end mt-2">
        <div class="col-md-4">
          <label class="top-search__label">都道府県</label>
          <%= f.collection_select :state_id, State.all, :id, :state,
              { include_blank: "すべての都道府県" },
              { class: "search-select w-100" } %>
        </div>
        <div class="col-md-4">
          <label class="top-search__label">エリア</label>
          <div id="areas_select_search">
            <select name="customer[area_id]" id="customer_area_id" class="search-select w-100">
              <option value="">すべてのエリア</option>
            </select>
          </div>
        </div>
        <div class="col-md-4">
          <%= button_tag type: :submit, class: "btn top-search__btn w-100" do %>
            <i class="fas fa-search me-1"></i>検索する
          <% end %>
        </div>
      </div>
      <p class="search-form-area-note mt-2">
        ※エリア区分の詳細は
        <%= link_to "こちら", about_path, class: "search-form-area-link", data: {"turbolinks" => false} %>
        をご覧ください
      </p>

    <% end %>

    <%# 簡易検索（ログイン済みのみ） %>
    <% if customer_signed_in? %>
      <hr class="search-form-divider">
      <p class="search-form-quick text-center">
        <i class="fas fa-user-circle me-1"></i>登録済みアレルゲンで
        <%= link_to "かんたん検索", simple_search_restaurants_path, class: "search-form-quick__link" %>
        もできます
      </p>
    <% end %>

  </div>
</div>

<script>
  window.addEventListener('pageshow', () => {
    if (window.performance.navigation.type == 2) location.reload();
  });

  document.addEventListener('DOMContentLoaded', function() {
    const chipWrap = document.getElementById('allergenChipWrap');
    const chipList = document.getElementById('allergenChipList');
    const allergenArea = document.getElementById('allergenArea');
    const allergenBadge = document.getElementById('allergenBadge');
    if (!chipWrap || !chipList) return;

    const checkboxes = document.querySelectorAll('#allergenArea input[type="checkbox"]');

    function buildChips() {
      chipList.innerHTML = '';
      let count = 0;
      checkboxes.forEach(function(cb) {
        if (!cb.checked) return;
        count++;
        const text = cb.closest('label').textContent.trim();
        const chip = document.createElement('span');
        chip.className = 'allergen-chip-item';
        chip.innerHTML =
          '<i class="fas fa-ban me-1"></i>' + text +
          '<button type="button" class="allergen-chip-item__remove" aria-label="解除">&times;</button>';
        chip.querySelector('button').addEventListener('click', function() {
          cb.checked = false;
          buildChips();
        });
        chipList.appendChild(chip);
      });
      chipWrap.classList.toggle('d-none', count === 0);
    }

    checkboxes.forEach(cb => cb.addEventListener('change', buildChips));
    buildChips();

    // 既選択がある場合は自動展開
    const anyChecked = Array.from(checkboxes).some(cb => cb.checked);
    if (anyChecked && allergenArea) {
      allergenArea.classList.add('show');
      const toggleBtn = document.querySelector('[data-bs-target="#allergenArea"]');
      if (toggleBtn) toggleBtn.setAttribute('aria-expanded', 'true');
      if (allergenBadge) {
        const count = Array.from(checkboxes).filter(cb => cb.checked).length;
        allergenBadge.textContent = count;
        allergenBadge.classList.remove('d-none');
      }
    }
  });
</script>
