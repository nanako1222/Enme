<%# ─── 上部お知らせ帯 ──────────────────────── %>
<div class="rest-notice-band">
  <div class="container">
    <p class="rest-notice-band__demo">
      <i class="fas fa-info-circle me-1"></i>現在登録されているデータは架空のサンプルデータです。
    </p>
  </div>
</div>

<%# ─── ページヘッダー ─────────────────────── %>
<div class="menu-list-header">
  <div class="container py-4">
    <div class="d-flex align-items-center justify-content-between flex-wrap gap-3">
      <div>
        <h1 class="menu-list-header__title">
          <i class="fas fa-clipboard-list me-2"></i>メニュー一覧
        </h1>
        <p class="menu-list-header__count">全 <strong><%= @menus_count %></strong> 品を掲載中</p>
      </div>
      <%= link_to restaurant_path(@restaurant), class: "btn menu-back-btn" do %>
        <i class="fas fa-store me-1"></i>店舗詳細に戻る
      <% end %>
    </div>
  </div>
</div>

<%# ─── メニューカード一覧 ───────────────── %>
<div class="container py-4 pb-5">
  <% if @menus.any? %>
    <div class="row g-4">
      <% @menus.each do |menu| %>
        <div class="col-6 col-md-4 col-lg-3">
          <div class="menu-card">
            <%= link_to restaurant_menu_path(@restaurant, menu), class: "text-decoration-none d-block" do %>
              <div class="menu-card__img-wrap">
                <%= image_tag(
                  menu.image.attached? ? menu.get_image(400, 280) : 'default-image.jpg',
                  class: "menu-card__img", alt: menu.name
                ) %>
              </div>
            <% end %>
            <div class="menu-card__body">
              <h5 class="menu-card__name">
                <%= link_to menu.name, restaurant_menu_path(@restaurant, menu),
                    class: "menu-card__name-link" %>
              </h5>
              <p class="menu-card__price">
                ¥<%= menu.with_tax_price %><span class="menu-card__price-unit">（税込）</span>
              </p>
              <p class="menu-card__allergen-label">アレルゲン</p>
              <% if menu.allergies.any? %>
                <div class="menu-card__allergens">
                  <% menu.allergies.each do |a| %>
                    <span class="menu-allergen-tag"><%= a.allergen %></span>
                  <% end %>
                </div>
              <% else %>
                <p class="menu-card__no-allergen">情報なし</p>
              <% end %>
            </div>
          </div>
        </div>
      <% end %>
    </div>

    <div class="d-flex justify-content-center mt-5 mb-2">
      <%= paginate @menus %>
    </div>
  <% end %>
</div>
