<%# ─── ヒーロー ─────────────────────────────── %>
<div class="auth-hero">
  <div class="container text-center py-4">
    <h1 class="auth-hero__title">新規会員登録</h1>
    <p class="auth-hero__sub">登録すると、アレルゲン情報の保存やお気に入りの飲食店管理ができます</p>
  </div>
</div>

<div class="container py-5">
  <div class="auth-card auth-card--wide mx-auto">

    <%= form_with model: @customer, url: customer_registration_path,
        id: 'new_customer', class: 'new_customer', local: true do |f| %>
      <%= render "customer/shared/error_messages", resource: resource %>

      <%# 名前 %>
      <div class="mb-4">
        <label class="auth-form__label">名前</label>
        <div class="d-flex gap-2">
          <%= f.text_field :first_name, placeholder: "姓", autofocus: true,
              class: "form-control auth-form__input" %>
          <%= f.text_field :last_name, placeholder: "名",
              class: "form-control auth-form__input" %>
        </div>
      </div>

      <%# フリガナ %>
      <div class="mb-4">
        <label class="auth-form__label">フリガナ</label>
        <div class="d-flex gap-2">
          <%= f.text_field :first_name_kana, placeholder: "セイ",
              class: "form-control auth-form__input" %>
          <%= f.text_field :last_name_kana, placeholder: "メイ",
              class: "form-control auth-form__input" %>
        </div>
      </div>

      <%# メールアドレス %>
      <div class="mb-4">
        <%= f.label :email, "メールアドレス", class: "auth-form__label" %>
        <%= f.email_field :email, class: "form-control auth-form__input" %>
      </div>

      <%# 都道府県・エリア %>
      <div class="row g-3 mb-1">
        <div class="col-md-6">
          <%= f.label :state_id, "都道府県", class: "auth-form__label" %>
          <%= f.collection_select :state_id, State.all, :id, :state,
              { selected: 1 },
              { class: "form-select auth-form__input" } %>
        </div>
        <div class="col-md-6">
          <%= f.label :area_id, "エリア", class: "auth-form__label" %>
          <div id="areas_select_customer">
            <%= render partial: 'shared/areas', locals: { areas: Area.where(state_id: 1) } %>
          </div>
        </div>
      </div>
      <p class="auth-area-note mb-4">
        ※エリア区分の詳細は
        <%= link_to "こちら", about_path, class: "auth-area-link",
            data: {"turbolinks" => false} %>
        をご覧ください
      </p>

      <%# 電話番号 %>
      <div class="mb-4">
        <%= f.label :telephone_number, "電話番号", class: "auth-form__label" %>
        <%= f.text_field :telephone_number, placeholder: "例：090-1234-5678",
            class: "form-control auth-form__input" %>
      </div>

      <%# パスワード %>
      <div class="mb-4">
        <%= f.label :password, class: "auth-form__label" do %>
          パスワード
          <% if @minimum_password_length %>
            <span class="auth-form__note">（<%= @minimum_password_length %>文字以上）</span>
          <% end %>
        <% end %>
        <%= f.password_field :password, class: "form-control auth-form__input" %>
      </div>

      <%# パスワード確認 %>
      <div class="mb-4">
        <%= f.label :password_confirmation, "パスワード（確認）", class: "auth-form__label" %>
        <%= f.password_field :password_confirmation, class: "form-control auth-form__input" %>
      </div>

      <div class="d-grid mt-2">
        <%= button_tag type: :submit, class: "btn auth-submit-btn" do %>
          <i class="fas fa-user-plus me-1"></i>登録する
        <% end %>
      </div>
    <% end %>

    <hr class="auth-divider my-4">

    <p class="text-center auth-sub-text">既に登録済みの方</p>
    <div class="text-center">
      <%= link_to new_customer_session_path, class: "btn auth-register-btn" do %>
        ログインはこちら
      <% end %>
    </div>

  </div>
</div>

<script>
  window.addEventListener('pageshow', () => {
    if (window.performance.navigation.type == 2) location.reload();
  });
</script>
