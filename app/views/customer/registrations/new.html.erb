<div class="container">
  <div class="col-11 col-md-8 mx-auto">

    <div class="text-center mt-5">
      <h4 class="text-center"><strong>新規会員登録</strong></h4>
    </div>

    <%= form_with model: @customer, url: customer_registration_path, id: 'new_customer', class: 'new_customer', local: true do |f| %>
      <%= render "customer/shared/error_messages", resource: resource %>

      <div class="row mt-3 align-items-center">
        <span class="col-md-4">名前</span>
        <div class="col-md-8 d-flex gap-2">
          <%= f.text_field :first_name, autofocus: true, placeholder: "姓", class: "flex-grow-1", style: "min-width: 0;" %>
          <%= f.text_field :last_name, placeholder: "名", class: "flex-grow-1", style: "min-width: 0;" %>
        </div>
      </div>

      <div class="row mt-3 align-items-center">
        <span class="col-md-4">フリガナ</span>
        <div class="col-md-8 d-flex gap-2">
          <%= f.text_field :first_name_kana, placeholder: "姓（カナ）", class: "flex-grow-1", style: "min-width: 0;" %>
          <%= f.text_field :last_name_kana, placeholder: "名（カナ）", class: "flex-grow-1", style: "min-width: 0;" %>
        </div>
      </div>

      <div class="row mt-3 align-items-center">
        <%= f.label :email, class: "col-md-4" %>
        <%= f.email_field :email, class: "col-md-8" %>
      </div>

      <div class="row mt-3 align-items-center">
        <%= f.label :state_id, class: "col-md-4" %>
        <%= f.collection_select :state_id, State.all, :id, :state, {selected: 1}, {class: "col-md-4"} %>
      </div>

      <div class="row mt-3 align-items-center">
        <%= f.label :area_id, class: "col-md-4" %>
        <div id="areas_select_customer" class="col-md-8">
          <%= render partial: 'shared/areas', locals: { areas: Area.where(state_id: 1) } %>
        </div>
      </div>

      <p class="text-center mt-2">
        ※エリア分け詳細は
        <%= link_to "こちら", about_path, class: "btn btn-outline-info btn-sm", data: {"turbolinks" => false} %>
        をご参考ください
      </p>

      <div class="row mt-3 align-items-center">
        <%= f.label :telephone_number, class: "col-md-4" %>
        <%= f.text_field :telephone_number, class: "col-md-8" %>
      </div>

      <div class="row mt-3 align-items-center">
        <div class="col-md-4">
          <%= f.label :password %>
          <% if @minimum_password_length %>
            <em>(<%= @minimum_password_length %> 文字以上)</em>
          <% end %>
        </div>
        <%= f.password_field :password, class: "col-md-8" %>
      </div>

      <div class="row mt-3 align-items-center">
        <%= f.label :password_confirmation, class: "col-md-4" %>
        <%= f.password_field :password_confirmation, class: "col-md-8" %>
      </div>

      <div class="mt-4 text-center">
        <%= button_tag type: :submit, class: "btn btn-success active" do %>
          <i class="fas fa-user-plus"></i> 新規登録
        <% end %>
      </div>

      <div class="text-center mt-5 mb-4">
        <h6 class="text-center">既に登録済みの方</h6>
        <p class="mt-3">
          <%= link_to "こちら", new_customer_session_path, class: "btn btn-outline-info btn-sm" %>
          からログインしてください。
        </p>
      </div>

    <% end %>
  </div>
</div>

<script>
  window.addEventListener('pageshow',()=>{
    if(window.performance.navigation.type==2) location.reload();
  });
</script>
