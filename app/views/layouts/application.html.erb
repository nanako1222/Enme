<!DOCTYPE html>
<html lang="ja">
  <head>
    <title>Enme</title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%= stylesheet_pack_tag 'application', 'data-turbolinks-track': 'reload' %>
    <%= javascript_pack_tag 'application', 'data-turbolinks-track': 'reload' %>

    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/5.15.4/css/all.min.css">
    <script>window.defaultImageUrl = "<%= asset_path('default-image.jpg') %>";</script>
  </head>

  <body>
    <div class="wrapper">

      <%# ─── Header ──────────────────────────────────── %>
      <header>
        <nav class="navbar navbar-expand-lg" id="global_nav">
          <div class="container">
            <a class="navbar-brand" href="/">
              <%= image_tag 'logo.png', height: '84', alt: 'Enme' %>
            </a>

            <button class="navbar-toggler" type="button"
                    data-bs-toggle="collapse" data-bs-target="#navbarNav"
                    aria-controls="navbarNav" aria-expanded="false">
              <span class="navbar-toggler-icon"></span>
            </button>

            <div class="collapse navbar-collapse" id="navbarNav">
              <ul class="navbar-nav ms-auto align-items-lg-center gap-1">
                <% if customer_signed_in? %>
                  <li class="nav-item"><%= link_to "飲食店検索", search_restaurants_path, class: "nav-link" %></li>
                  <li class="nav-item"><%= link_to "簡易検索", simple_search_restaurants_path, class: "nav-link" %></li>
                  <li class="nav-item"><%= link_to "お気に入り", customers_favorite_index_path, class: "nav-link" %></li>
                  <li class="nav-item"><%= link_to "マイページ", my_page_path, class: "nav-link" %></li>
                  <li class="nav-item"><%= link_to "About", about_path, class: "nav-link", data: {"turbolinks" => false} %></li>
                  <li class="nav-item ms-lg-2">
                    <%= link_to "ログアウト", destroy_customer_session_path, method: :delete, class: "btn nav-btn-outline" %>
                  </li>
                <% elsif admin_signed_in? %>
                  <li class="nav-item"><%= link_to "顧客一覧", admin_customers_path, class: "nav-link" %></li>
                  <li class="nav-item"><%= link_to "アレルゲン一覧", admin_allergies_path, class: "nav-link" %></li>
                  <li class="nav-item"><%= link_to "飲食店一覧", admin_path, class: "nav-link" %></li>
                  <li class="nav-item"><%= link_to "地域一覧", admin_areas_index_path, class: "nav-link" %></li>
                  <li class="nav-item ms-lg-2">
                    <%= link_to "ログアウト", destroy_admin_session_path, method: :delete, class: "btn nav-btn-outline" %>
                  </li>
                <% elsif restaurant_signed_in? %>
                  <li class="nav-item"><%= link_to "店舗情報", restaurant_homes_path, class: "nav-link" %></li>
                  <li class="nav-item"><%= link_to "メニュー一覧", restaurant_restaurant_menus_path(current_restaurant), class: "nav-link" %></li>
                  <li class="nav-item"><%= link_to "メニュー追加", new_restaurant_restaurant_menu_path(current_restaurant), class: "nav-link" %></li>
                  <li class="nav-item"><%= link_to "About", restaurant_about_path, class: "nav-link", data: {"turbolinks" => false} %></li>
                  <li class="nav-item ms-lg-2">
                    <%= link_to "ログアウト", destroy_restaurant_session_path, method: :delete, class: "btn nav-btn-outline" %>
                  </li>
                <% else %>
                  <li class="nav-item"><%= link_to "飲食店検索", search_restaurants_path, class: "nav-link" %></li>
                  <li class="nav-item"><%= link_to "About", about_path, class: "nav-link", data: {"turbolinks" => false} %></li>
                  <li class="nav-item"><%= link_to "店舗登録", new_restaurant_registration_path, class: "nav-link", data: {"turbolinks": false} %></li>
                  <li class="nav-item ms-lg-2">
                    <%= link_to "ログイン", new_customer_session_path, class: "btn nav-btn-outline" %>
                  </li>
                  <li class="nav-item">
                    <%= link_to "新規会員登録", new_customer_registration_path, class: "btn nav-btn-primary", data: {"turbolinks": false} %>
                  </li>
                <% end %>
              </ul>
            </div>
          </div>
        </nav>
      </header>

      <main>
        <% if flash[:notice] %>
          <div class="flash-notice alert alert-dismissible fade show mb-0" role="alert">
            <i class="fas fa-check-circle me-2"></i><%= flash[:notice] %>
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="閉じる"></button>
          </div>
        <% end %>
        <% if flash[:alert] %>
          <div class="flash-alert alert alert-dismissible fade show mb-0" role="alert">
            <i class="fas fa-exclamation-circle me-2"></i><%= flash[:alert] %>
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="閉じる"></button>
          </div>
        <% end %>
        <%= yield %>
      </main>

    </div>

    <%# ─── Footer ──────────────────────────────────────── %>
    <footer id="site-footer">
      <div class="container">
        <div class="row py-5 g-4">

          <%# ロゴ・タグライン %>
          <div class="col-md-4 mb-2 mb-md-0">
            <%= image_tag 'logo.png', height: '68', alt: 'Enme', class: "footer-logo" %>
            <p class="footer-tagline mt-2 mb-0">アレルギーがあっても、安心して外食を。</p>
          </div>

          <%# サービスリンク %>
          <div class="col-md-4">
            <p class="footer-nav-title">サービス</p>
            <ul class="footer-nav-list">
              <li><%= link_to "About", about_path, class: "footer-link", data: {"turbolinks" => false} %></li>
              <li><%= link_to "利用規約", terms_path, class: "footer-link" %></li>
              <li><%= link_to "お問い合わせ", contact_path, class: "footer-link" %></li>
            </ul>
          </div>

          <%# 店舗オーナー向け %>
          <div class="col-md-4">
            <p class="footer-nav-title">飲食店オーナーの方</p>
            <ul class="footer-nav-list">
              <%= content_tag :li, link_to("店舗会員登録", new_restaurant_registration_path, class: "footer-link", data: {"turbolinks": false}) %>
              <%= content_tag :li, link_to("店舗ログイン", new_restaurant_session_path, class: "footer-link") %>
            </ul>
          </div>

        </div>
        <div class="footer-bottom text-center py-3">
          <p class="mb-0 small">©<%= Time.now.year %> Enme</p>
        </div>
      </div>
    </footer>

  </body>
</html>
