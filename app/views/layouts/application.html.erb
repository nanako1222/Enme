<!DOCTYPE html>
<html>
  <head>
    <title>Enme</title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%= stylesheet_pack_tag 'application', media: 'all', 'data-turbolinks-track': 'reload' %>
    <link href="https://cdnjs.cloudflare.com/ajax/libs/lightbox2/2.7.1/css/lightbox.css" rel="stylesheet">
  </head>

  <body>
    <div class="wrapper" style="min-height: 100vh; display: flex; flex-direction: column;">
      <header>
        <nav class="navbar navbar-expand-lg navbar-dark" id="global_nav">
          <div class="container">

            <% if customer_signed_in? %>
              <a class="navbar-brand" href="/">
                <%= image_tag('logo.png', size:'200x60') %>
              </a>
              <button class="navbar-toggler" type="button" data-toggle="collapse" data-target="#navbarNavDropdown" aria-controls="navbarNavDropdown" aria-expanded="false" aria-label="Toggle navigation">
                <span class="navbar-toggler-icon"></span>
              </button>
              <div class="navbar-collapse collapse" id="navbarNavDropdown">
                <ul class="navbar-nav ml-auto" id="nav_links" style="color: #800000;">
                  <li><%= link_to "会員情報詳細", my_page_path, class:"nav-link text-light font-weight-bold" %></li>
                  <li><%= link_to "飲食店検索", search_restaurants_path, class:"nav-link text-light font-weight-bold" %></li>
                  <li><%= link_to "飲食店簡易検索", simple_search_restaurants_path, class:"nav-link text-light font-weight-bold" %></li>
                  <li><%= link_to "お気に入り一覧", customers_favorite_index_path, class:"nav-link text-light font-weight-bold" %></li>
                  <li><%= link_to "About", about_path, class:"nav-link text-light font-weight-bold", data: {"turbolinks" => false} %></li>
                  <li><%= link_to "ログアウト", destroy_customer_session_path, method: :delete, class:"nav-link text-light font-weight-bold" %></li>
                </ul>
              </div>

            <% elsif admin_signed_in? %>
              <a class="navbar-brand" href="/admin">
                <%= image_tag('logo.png', size:'200x60') %>
              </a>
              <button class="navbar-toggler" type="button" data-toggle="collapse" data-target="#navbarNavDropdown" aria-controls="navbarNavDropdown" aria-expanded="false" aria-label="Toggle navigation">
                <span class="navbar-toggler-icon"></span>
              </button>
              <div class="navbar-collapse collapse" id="navbarNavDropdown">
                <ul class="navbar-nav ml-auto">
                  <li><%= link_to "顧客一覧", admin_customers_path, class:"nav-link text-light font-weight-bold" %></li>
                  <li><%= link_to "アレルゲン一覧", admin_allergies_path, class:"nav-link text-light font-weight-bold" %></li>
                  <li><%= link_to "飲食店一覧", admin_path, class:"nav-link text-light font-weight-bold" %></li>
                  <li><%= link_to "地域一覧", admin_areas_index_path, class:"nav-link text-light font-weight-bold" %></li>
                  <li><%= link_to "ログアウト", destroy_admin_session_path, method: :delete, class:"nav-link text-light font-weight-bold" %></li>
                </ul>
              </div>

            <% elsif restaurant_signed_in? %>
              <a class="navbar-brand" href="/restaurant">
                <%= image_tag('logo.png', size:'200x60') %>
              </a>
              <button class="navbar-toggler" type="button" data-toggle="collapse" data-target="#navbarNavDropdown" aria-controls="navbarNavDropdown" aria-expanded="false" aria-label="Toggle navigation">
                <span class="navbar-toggler-icon"></span>
              </button>
              <div class="navbar-collapse collapse" id="navbarNavDropdown">
                <ul class="navbar-nav ml-auto">
                  <li><%= link_to "登録情報詳細", restaurant_homes_path, class:"nav-link text-light font-weight-bold ml-3" %></li>
                  <li><%= link_to "メニュー一覧", restaurant_restaurant_menus_path(@restaurant), class:"nav-link text-light font-weight-bold ml-3" %></li>
                  <li><%= link_to "メニュー追加", new_restaurant_restaurant_menu_path(@restaurant), class:"nav-link text-light font-weight-bold ml-3" %></li>
                  <li><%= link_to "About", restaurant_about_path, class:"nav-link text-light font-weight-bold ml-3", data: {"turbolinks" => false} %></li>
                  <li><%= link_to "ログアウト", destroy_restaurant_session_path, method: :delete, class:"nav-link text-light font-weight-bold ml-3" %></li>
                </ul>
              </div>

            <% else %>
              <a class="navbar-brand" href="/">
                <%= image_tag('logo.png', size:'200x60') %>
              </a>
              <button class="navbar-toggler" type="button" data-toggle="collapse" data-target="#navbarNavDropdown" aria-controls="navbarNavDropdown" aria-expanded="false" aria-label="Toggle navigation">
                <span class="navbar-toggler-icon"></span>
              </button>
              <div class="navbar-collapse collapse" id="navbarNavDropdown">
                <ul class="navbar-nav ml-auto">
                  <li><%= link_to "About", about_path, class:"nav-link text-light font-weight-bold ml-3", data: {"turbolinks" => false} %></li>
                  <li><%= link_to "飲食店検索", search_restaurants_path, class:"nav-link text-light font-weight-bold ml-3" %></li>
                  <li><%= link_to "新規登録", new_customer_registration_path, class:"nav-link text-light font-weight-bold ml-3", data: {"turbolinks": false} %></li>
                  <li><%= link_to "ログイン", new_customer_session_path, class:"nav-link text-light font-weight-bold ml-3" %></li>
                </ul>
              </div>
            <% end %>
          </div>
        </nav>
      </header>

      <main style="flex: 1;">
        <%= yield %>
      </main>

      <footer class="text-white pt-5 pb-4 bg-dark">
        <div class="container">
          <div class="row no-gutters">
            <% unless signed_in? %>
              <div class="col-md-3">
                <%= link_to "店舗新規会員登録", new_restaurant_registration_path, class:"nav-link text-light font-weight-bold", data: {"turbolinks": false} %>
                <%= link_to "店舗ログイン", new_restaurant_session_path, class:"nav-link text-light font-weight-bold" %>
              </div>
              <div class="col-md-9 text-center">
                <p>©2022 Enme</p>
              </div>
            <% else %>
              <div class="col-md-12 text-center">
                <p>©2022 Enme</p>
              </div>
            <% end %>
          </div>
        </div>
      </footer>
    </div>

    <%# --- JavaScript実行環境の安定化 --- %>
    <script src="https://ajax.googleapis.com/ajax/libs/jquery/3.1.1/jquery.min.js"></script>
    <%= javascript_pack_tag 'application', 'data-turbolinks-track': 'reload' %>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/lightbox2/2.7.1/js/lightbox.min.js" type="text/javascript"></script>
  </body>
</html>
