<%# ─── 上部お知らせ帯 ──────────────────────── %>
<div class="rest-notice-band">
  <div class="container">
    <p class="rest-notice-band__demo">
      <i class="fas fa-info-circle me-1"></i>現在登録されているデータは架空のサンプルデータです。
    </p>
  </div>
</div>

<%# ─── ページヘッダー ─────────────────────── %>
<div class="menu-list-header">
  <div class="container py-4">
    <div class="d-flex align-items-center justify-content-between flex-wrap gap-3">
      <div>
        <h1 class="menu-list-header__title">
          <i class="fas fa-store me-2"></i>店舗情報
        </h1>
        <p class="menu-list-header__count"><strong><%= @restaurant.name %></strong></p>
      </div>
      <div class="d-flex gap-2">
        <%= link_to restaurant_path(@restaurant), class: "btn menu-back-btn", target: "_blank", rel: "noopener" do %>
          <i class="fas fa-external-link-alt me-1"></i>公開ページを確認
        <% end %>
        <%= link_to restaurant_information_edit_path, class: "btn auth-submit-btn" do %>
          <i class="fas fa-pen-nib me-1"></i>情報を編集
        <% end %>
      </div>
    </div>
  </div>
</div>

<%# ─── 情報カード ──────────────────────────── %>
<div class="container py-4 pb-5">
  <div class="mypage-card" style="max-width: 820px;">

    <%# 画像 + 紹介文 %>
    <div class="row g-4 align-items-start mb-4">
      <div class="col-md-4 text-center">
        <% if @restaurant.image.attached? %>
          <%= image_tag @restaurant.get_image(300, 220),
              class: "rest-top-img", alt: @restaurant.name %>
        <% else %>
          <%= image_tag 'default-image.jpg',
              class: "rest-top-img", alt: @restaurant.name %>
        <% end %>
      </div>
      <div class="col-md-8">
        <h2 class="mypage-card__section-title">
          <i class="fas fa-align-left me-2"></i>店舗紹介
        </h2>
        <div class="rest-top-intro mt-3">
          <%= simple_format(@restaurant.introduction.presence || "（未登録）") %>
        </div>
      </div>
    </div>

    <%# 基本情報 %>
    <h2 class="mypage-card__section-title">
      <i class="fas fa-id-card me-2"></i>基本情報
    </h2>
    <dl class="mypage-dl">
      <div class="mypage-dl__row">
        <dt class="mypage-dl__label">都道府県</dt>
        <dd class="mypage-dl__value"><%= @state %></dd>
      </div>
      <div class="mypage-dl__row">
        <dt class="mypage-dl__label">地域エリア</dt>
        <dd class="mypage-dl__value"><%= @area %></dd>
      </div>
      <div class="mypage-dl__row">
        <dt class="mypage-dl__label">住所</dt>
        <dd class="mypage-dl__value"><%= @restaurant.address.presence || "（未登録）" %></dd>
      </div>
      <div class="mypage-dl__row">
        <dt class="mypage-dl__label">電話番号</dt>
        <dd class="mypage-dl__value"><%= @restaurant.telephone_number.presence || "（未登録）" %></dd>
      </div>
      <div class="mypage-dl__row">
        <dt class="mypage-dl__label">メールアドレス</dt>
        <dd class="mypage-dl__value"><%= @restaurant.email %></dd>
      </div>
      <div class="mypage-dl__row">
        <dt class="mypage-dl__label">定休日</dt>
        <dd class="mypage-dl__value"><%= @restaurant.regular_holiday.presence || "（未登録）" %></dd>
      </div>
      <div class="mypage-dl__row">
        <dt class="mypage-dl__label">営業時間</dt>
        <dd class="mypage-dl__value"><%= @restaurant.business_hours.presence || "（未登録）" %></dd>
      </div>
      <div class="mypage-dl__row">
        <dt class="mypage-dl__label">ホームページ</dt>
        <dd class="mypage-dl__value">
          <% if @restaurant.home_page.present? %>
            <%= link_to @restaurant.home_page, @restaurant.home_page,
                target: "_blank", rel: "noopener", class: "rest-top-link" %>
          <% else %>
            （未登録）
          <% end %>
        </dd>
      </div>
      <div class="mypage-dl__row">
        <dt class="mypage-dl__label">駐車場</dt>
        <dd class="mypage-dl__value"><%= @restaurant.parking.presence || "（未登録）" %></dd>
      </div>
    </dl>

    <%# お知らせ・新着情報 %>
    <% if @restaurant.news.present? %>
      <h2 class="mypage-card__section-title mt-4">
        <i class="fas fa-bullhorn me-2"></i>お知らせ・新着情報
      </h2>
      <div class="rest-top-intro mt-3">
        <%= simple_format(@restaurant.news) %>
      </div>
    <% end %>

  </div>
</div>
