<%# ─── 退会確認 ───────────────────────────── %>
<div class="container py-5">
  <div class="rest-confirm-card mx-auto mt-4">

    <div class="text-center mb-4">
      <i class="fas fa-exclamation-triangle rest-confirm__icon"></i>
    </div>

    <h1 class="rest-confirm__title text-center">退会の確認</h1>
    <p class="rest-confirm__text text-center mt-3">
      退会すると、店舗情報・メニュー情報がすべて削除され、<br>
      Enmeへの掲載が終了します。<br>
      この操作は取り消せません。
    </p>

    <div class="d-flex gap-3 justify-content-center mt-4">
      <%= link_to restaurant_homes_path, class: "btn rest-confirm__cancel-btn" do %>
        <i class="fas fa-arrow-left me-1"></i>退会しない
      <% end %>
      <%= link_to restaurant_out_path,
          "data-confirm": "本当に退会しますか？",
          method: :patch,
          class: "btn rest-confirm__danger-btn" do %>
        <i class="fas fa-store-slash me-1"></i>退会する
      <% end %>
    </div>

  </div>
</div>
