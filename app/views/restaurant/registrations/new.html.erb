<%# ─── ヒーロー ─────────────────────────────── %>
<div class="auth-hero">
  <div class="container text-center py-4">
    <h1 class="auth-hero__title">飲食店新規登録</h1>
    <p class="auth-hero__sub">アレルゲン対応メニューを掲載して、新しいお客様との出会いを</p>
  </div>
</div>

<div class="container py-5">
  <div class="auth-card auth-card--wide mx-auto">

    <%= form_with model: @restaurant, url: restaurant_registration_path,
        id: 'new_restaurant', class: 'new_restaurant', local: true do |f| %>
      <%= render "restaurant/shared/error_messages", resource: resource %>

      <%# 店舗名 %>
      <div class="mb-4">
        <%= f.label :name, "店舗名", class: "auth-form__label" %>
        <%= f.text_field :name, autofocus: true, class: "form-control auth-form__input" %>
      </div>

      <%# メールアドレス %>
      <div class="mb-4">
        <%= f.label :email, "メールアドレス", class: "auth-form__label" %>
        <%= f.email_field :email, class: "form-control auth-form__input" %>
      </div>

      <%# 都道府県・エリア %>
      <div class="row g-3 mb-1">
        <div class="col-md-6">
          <%= f.label :state_id, "都道府県", class: "auth-form__label" %>
          <%= f.collection_select :state_id, State.all.presence || [], :id, :state,
              { include_blank: "都道府県を選択してください" },
              { class: "form-select auth-form__input" } %>
        </div>
        <div class="col-md-6">
          <%= f.label :area_id, "エリア", class: "auth-form__label" %>
          <div id="areas_select">
            <% first_state = State.first %>
            <%= render partial: 'shared/restaurant_areas',
                locals: { areas: first_state ? Area.where(state_id: first_state.id) : [] } %>
          </div>
        </div>
      </div>
      <p class="auth-area-note mb-4">
        ※エリア区分の詳細は
        <%= link_to "こちら", about_path, class: "auth-area-link",
            data: {"turbolinks" => false} %>
        をご覧ください
      </p>

      <%# 住所 %>
      <div class="mb-4">
        <%= f.label :address, "住所", class: "auth-form__label" %>
        <%= f.text_field :address, class: "form-control auth-form__input" %>
      </div>

      <%# 電話番号 %>
      <div class="mb-4">
        <%= f.label :telephone_number, "電話番号", class: "auth-form__label" %>
        <%= f.text_field :telephone_number, placeholder: "例：06-1234-5678",
            class: "form-control auth-form__input" %>
      </div>

      <%# 定休日・営業時間 %>
      <div class="row g-3 mb-4">
        <div class="col-md-6">
          <%= f.label :regular_holiday, "定休日", class: "auth-form__label" %>
          <%= f.text_field :regular_holiday, placeholder: "例：毎週水曜日",
              class: "form-control auth-form__input" %>
        </div>
        <div class="col-md-6">
          <%= f.label :business_hours, "営業時間", class: "auth-form__label" %>
          <%= f.text_field :business_hours, placeholder: "例：11:00〜22:00",
              class: "form-control auth-form__input" %>
        </div>
      </div>

      <%# パスワード %>
      <div class="mb-4">
        <%= f.label :password, class: "auth-form__label" do %>
          パスワード
          <% if @minimum_password_length %>
            <span class="auth-form__note">（<%= @minimum_password_length %>文字以上）</span>
          <% end %>
        <% end %>
        <%= f.password_field :password, class: "form-control auth-form__input" %>
      </div>

      <%# パスワード確認 %>
      <div class="mb-4">
        <%= f.label :password_confirmation, "パスワード（確認）", class: "auth-form__label" %>
        <%= f.password_field :password_confirmation, class: "form-control auth-form__input" %>
      </div>

      <div class="d-grid mt-2">
        <%= button_tag type: :submit, class: "btn auth-submit-btn" do %>
          <i class="fas fa-store me-1"></i>登録する
        <% end %>
      </div>
    <% end %>

    <hr class="auth-divider my-4">

    <p class="text-center auth-sub-text">既に登録済みの方</p>
    <div class="text-center">
      <%= link_to new_restaurant_session_path, class: "btn auth-register-btn" do %>
        ログインはこちら
      <% end %>
    </div>

  </div>
</div>
