<%# ─── ヒーロー ─────────────────────────────── %>
<div class="auth-hero">
  <div class="container text-center py-4">
    <h1 class="auth-hero__title">メニューを編集</h1>
    <p class="auth-hero__sub">内容を変更し、「保存する」を押してください</p>
  </div>
</div>

<div class="container py-5">
  <div class="auth-card auth-card--wide mx-auto">

    <%= form_with model: @menu, url: restaurant_restaurant_menu_path, method: :patch do |f| %>

      <%# 画像 %>
      <div class="mb-4">
        <%= f.label :image, "メニュー画像", class: "auth-form__label" %>
        <% if @menu.image.attached? %>
          <div class="mb-2">
            <%= image_tag @menu.get_image(120, 80),
                class: "rest-edit-thumb", alt: @menu.name %>
          </div>
        <% end %>
        <%= f.file_field :image, accept: "image/*", class: "form-control auth-form__input" %>
      </div>

      <%# メニュー名 %>
      <div class="mb-4">
        <%= f.label :name, "メニュー名", class: "auth-form__label" %>
        <%= f.text_field :name, autofocus: true, required: true,
            class: "form-control auth-form__input" %>
      </div>

      <%# アレルゲン %>
      <div class="mb-4">
        <p class="auth-form__label mb-2">含まれるアレルゲン（該当するものをすべて選択）</p>
        <div class="rest-allergen-grid">
          <%= f.collection_check_boxes(:allergy_ids, @allergies, :id, :allergen,
              checked: @menu.allergy_ids, include_hidden: false) do |a| %>
            <label class="rest-allergen-check">
              <%= a.check_box(class: "rest-allergen-check__input") %>
              <span class="rest-allergen-check__label"><%= a.text %></span>
            </label>
          <% end %>
        </div>
      </div>

      <%# 価格 %>
      <div class="mb-4">
        <%= f.label :price, "価格（税抜）", class: "auth-form__label" %>
        <div class="d-flex align-items-center gap-2">
          <%= f.text_field :price, required: true,
              class: "form-control auth-form__input", style: "max-width: 160px;" %>
          <span class="auth-form__note">円（税抜）</span>
        </div>
      </div>

      <%# 説明 %>
      <div class="mb-4">
        <%= f.label :introduction, "メニュー説明", class: "auth-form__label" %>
        <%= f.text_area :introduction, rows: 5, class: "form-control auth-form__input" %>
      </div>

      <div class="d-grid mt-2">
        <%= button_tag type: :submit, class: "btn auth-submit-btn" do %>
          <i class="fas fa-save me-1"></i>保存する
        <% end %>
      </div>

    <% end %>

    <hr class="auth-divider my-4">
    <div class="text-center">
      <%= link_to restaurant_restaurant_menus_path(@restaurant), class: "btn auth-register-btn" do %>
        <i class="fas fa-arrow-left me-1"></i>メニュー一覧に戻る
      <% end %>
    </div>

  </div>
</div>
