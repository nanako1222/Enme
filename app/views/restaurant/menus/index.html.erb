<div class="container">
  <div class="col-11 col-md-10 mx-auto">

    <h4 class="text-center mt-5">店舗メニュー一覧 <span class="fs-6"><%= "(全#{@menus_count}件)" %></span></h4>

    <div class="flashing mt-2">
      <p>※現在登録されているデータは架空です</p>
    </div>
    <div class="mt-3">
      <% if flash[:notice] %>
        <%= notice %>
      <% end %>
    </div>

    <div class="row mt-4">
      <% @menus.each do |menu| %>
        <div class="col-6 col-md-4 mb-4 text-center">
          <div class="item_image">
            <% if menu.image.attached? %>
              <%= link_to restaurant_restaurant_menu_path(@restaurant, menu) do %>
                <%= image_tag menu.get_image(100,100), class: "img-fluid rounded" %>
              <% end %>
            <% else %>
              <%= link_to restaurant_restaurant_menu_path(@restaurant, menu) do %>
                <%= image_tag 'default-image.jpg', size: "100x100", class: "img-fluid rounded" %>
              <% end %>
            <% end %>
          </div>
          <p class="p_1 mt-2"><%= link_to menu.name, restaurant_restaurant_menu_path(@restaurant, menu) %></p>
          <p class="p_1"><%= "¥#{menu.price}" %></p>
          <p class="p_1 small text-muted">
            <% menu.allergies.each do |e| %>
              <%= e.allergen %>
            <% end %>
          </p>
        </div>
      <% end %>
    </div>

    <div class="d-flex justify-content-center mt-3"><%= paginate @menus %></div>

  </div>
</div>
